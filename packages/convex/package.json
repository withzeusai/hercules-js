{
  "name": "@usehercules/convex",
  "version": "1.0.1",
  "description": "Convex IAM utilities for Hercules applications",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./iam-helpers": {
      "types": "./dist/client/iam-helpers.d.ts",
      "default": "./dist/client/iam-helpers.js"
    },
    "./http": {
      "types": "./dist/client/http.d.ts",
      "default": "./dist/client/http.js"
    },
    "./checker": {
      "types": "./dist/checker/index.d.ts",
      "default": "./dist/checker/index.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./_generated/component.js": {
      "types": "./dist/_generated/component.d.ts",
      "default": "./dist/_generated/component.js"
    },
    "./_generated/component": {
      "types": "./dist/_generated/component.d.ts",
      "default": "./dist/_generated/component.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "hercules-convex-iam-check": "./dist/checker/cli.js"
  },
  "author": "Hercules Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withzeusai/hercules-js.git",
    "directory": "packages/convex"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc --project ./tsconfig.build.json && node ./scripts/check-esm-exports.mjs",
    "dev": "tsc --project ./tsconfig.build.json --watch",
    "test": "vitest --run"
  },
  "dependencies": {
    "@usehercules/sdk": "^1.15.13",
    "convex-helpers": "0.1.120",
    "standardwebhooks": "^1.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "convex": "^1.34.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/node": "^24.13.2",
    "convex": "^1.42.1",
    "convex-test": "^0.0.54",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "main": "./dist/client/index.js",
  "module": "./dist/client/index.js",
  "types": "./dist/client/index.d.ts"
}
