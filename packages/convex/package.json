{
  "name": "@usehercules/convex",
  "version": "0.0.0",
  "description": "Convex Access Control utilities for Hercules applications",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./http": {
      "types": "./dist/client/http.d.ts",
      "default": "./dist/client/http.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./package.json": "./package.json"
  },
  "author": "Hercules Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withzeusai/hercules-js.git",
    "directory": "packages/convex"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "tsconfig.build.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --project ./tsconfig.build.json",
    "dev": "tsc --project ./tsconfig.build.json --watch",
    "test": "vitest --run"
  },
  "dependencies": {
    "standardwebhooks": "^1.0.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "convex": "^1.34.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.15",
    "convex": "^1.34.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "main": "./dist/client/index.js",
  "module": "./dist/client/index.js",
  "types": "./dist/client/index.d.ts"
}
